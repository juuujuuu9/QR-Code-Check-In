---
import { ThemeToggle } from './ThemeToggle';
import { SignOutButton } from '@clerk/astro/components';

type HeaderLink = {
  href: string;
  label: string;
};

type NavSegment = {
  label: string;
  href?: string;
  badge?: string;
  badgeColor?: 'default' | 'muted' | 'primary' | 'secondary';
};

interface Props {
  homeHref?: string;
  homeLabel?: string;
  // Breadcrumb navigation segments
  organization?: NavSegment;
  event?: NavSegment;
  // Legacy props (deprecated, use organization/event instead)
  secondaryLinks?: HeaderLink[];
  showThemeToggle?: boolean;
  showSignOut?: boolean;
  isAdmin?: boolean;
  userEmail?: string;
  userRole?: string;
}

const {
  homeHref = '/admin',
  homeLabel = 'Dashboard',
  organization,
  event,
  secondaryLinks = [],
  showThemeToggle = false,
  showSignOut = false,
  isAdmin = false,
  userEmail = '',
  userRole = '',
} = Astro.props;

const roleLabel = userRole === 'organizer' ? 'Organizer' : userRole === 'staff' ? 'Staff' : '';

const badgeClasses = {
  default: 'bg-muted text-muted-foreground',
  muted: 'bg-muted text-muted-foreground',
  primary: 'bg-primary/10 text-primary',
  secondary: 'bg-secondary text-secondary-foreground',
};
---

<header class="bg-card border-b border-border sticky top-0 z-50">
  <div class="w-full px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Breadcrumb Navigation -->
      <nav class="flex items-center gap-2" aria-label="Breadcrumb">
        <!-- Dashboard Home -->
        <a href={homeHref} class="flex items-center gap-2 text-foreground hover:text-primary transition-colors">
          <div class="bg-primary p-1.5 rounded-md">
            <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <span class="font-semibold text-sm">{homeLabel}</span>
        </a>

        <!-- Organization Segment -->
        {organization && (
          <>
            <span class="text-muted-foreground">/</span>
            <div class="flex items-center gap-2">
              {organization.href ? (
                <a href={organization.href} class="flex items-center gap-2 text-sm text-foreground hover:text-primary transition-colors">
                  {organization.label}
                  {organization.badge && (
                    <span class={`rounded px-1.5 py-0.5 text-xs font-medium ${badgeClasses[organization.badgeColor || 'default']}`}>
                      {organization.badge}
                    </span>
                  )}
                </a>
              ) : (
                <div class="flex items-center gap-2 text-sm text-foreground">
                  {organization.label}
                  {organization.badge && (
                    <span class={`rounded px-1.5 py-0.5 text-xs font-medium ${badgeClasses[organization.badgeColor || 'default']}`}>
                      {organization.badge}
                    </span>
                  )}
                </div>
              )}
            </div>
          </>
        )}

        <!-- Event Segment -->
        {event && (
          <>
            <span class="text-muted-foreground">/</span>
            <div class="flex items-center gap-2">
              {event.href ? (
                <a href={event.href} class="flex items-center gap-2 text-sm text-foreground hover:text-primary transition-colors">
                  {event.label}
                  {event.badge && (
                    <span class={`rounded px-1.5 py-0.5 text-xs font-medium ${badgeClasses[event.badgeColor || 'default']}`}>
                      {event.badge}
                    </span>
                  )}
                </a>
              ) : (
                <div class="flex items-center gap-2 text-sm text-foreground">
                  {event.label}
                  {event.badge && (
                    <span class={`rounded px-1.5 py-0.5 text-xs font-medium ${badgeClasses[event.badgeColor || 'default']}`}>
                      {event.badge}
                    </span>
                  )}
                </div>
              )}
            </div>
          </>
        )}

        <!-- Legacy secondary links (for backward compatibility) -->
        {secondaryLinks.map((link) => (
          <>
            <span class="text-muted-foreground">/</span>
            <a href={link.href} class="text-sm text-muted-foreground hover:text-primary transition-colors">{link.label}</a>
          </>
        ))}
      </nav>
      {(showThemeToggle || showSignOut || isAdmin || userEmail) && (
        <div class="flex items-center gap-4">
          {userEmail && (
            <div class="flex items-center gap-2 text-sm">
              <span class="text-muted-foreground">{userEmail}</span>
              {roleLabel && (
                <span class="rounded-full bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground">
                  {roleLabel}
                </span>
              )}
            </div>
          )}
          {showThemeToggle && <ThemeToggle client:load />}
          {isAdmin && organization && (
            <button
              id="open-invite-staff-modal-header"
              type="button"
              class="rounded-md border border-border bg-card px-3 py-2 text-sm font-medium text-foreground hover:bg-muted"
            >
              Invite Staff
            </button>
          )}
          {showSignOut && (
            <SignOutButton asChild redirectUrl="/">
              <button type="button" class="text-sm text-muted-foreground hover:text-primary bg-transparent border-none cursor-pointer p-0 font-inherit">Sign out</button>
            </SignOutButton>
          )}
        </div>
      )}
    </div>
  </div>
</header>
