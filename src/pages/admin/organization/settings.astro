---
import Layout from '../../../layouts/Layout.astro';
import DashboardHeader from '../../../components/DashboardHeader.astro';
import { getOrganizationByOwnerUserId } from '../../../lib/db';

const userId = Astro.locals.user?.id ?? '';
const organization = userId ? await getOrganizationByOwnerUserId(userId) : null;
---

<Layout title="Organization | Settings">
  <div class="min-h-screen bg-background">
    <DashboardHeader
      homeHref="/admin"
      homeLabel="Dashboard"
      showThemeToggle={true}
      showSignOut={true}
      isAdmin={Astro.locals.isAdmin}
      userEmail={Astro.locals.user?.email ?? ''}
      userRole={Astro.locals.user?.role ?? ''}
      organization={organization ? { label: organization.name, href: '/admin/organization' } : undefined}
    />
    <div class="flex min-h-[calc(100vh-4rem)]">
      {/* Sidebar Navigation */}
      {organization && (
        <aside class="w-64 border-r border-border bg-card hidden md:block">
          <nav class="p-4 space-y-1">
            <a
              href="/admin/organization"
              class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md text-muted-foreground hover:bg-muted hover:text-foreground transition-colors"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
              </svg>
              Overview
            </a>
            <a
              href="/admin/organization/staff"
              class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md text-muted-foreground hover:bg-muted hover:text-foreground transition-colors"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              Staff
            </a>
            <a
              href="/admin/organization/billing"
              class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md text-muted-foreground hover:bg-muted hover:text-foreground transition-colors"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
              </svg>
              Billing
            </a>
            <a
              href="/admin/organization/settings"
              class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md bg-primary/10 text-primary"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Settings
            </a>
          </nav>
        </aside>
      )}

      <main class="flex-1 px-4 py-10 space-y-6">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-foreground">Settings</h1>
            <p class="mt-1 text-sm text-muted-foreground">Manage your organization preferences.</p>
          </div>
        </div>

        {!organization ? (
          <div class="rounded-lg border border-(--amber-6) bg-(--amber-2) p-4 text-(--amber-11)">
            <p class="font-medium">No organizer organization found</p>
            <p class="mt-1 text-sm">Create one first to manage settings.</p>
            <a href="/onboarding/organization" class="mt-3 inline-flex rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">
              Create organization
            </a>
          </div>
        ) : (
          <section class="rounded-xl border border-border bg-card p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4">Organization details</h2>
            <form class="space-y-4 max-w-md">
              <div>
                <label for="org-name" class="block text-sm font-medium text-foreground mb-1">Organization name</label>
                <input
                  type="text"
                  id="org-name"
                  name="name"
                  value={organization.name}
                  disabled
                  class="w-full rounded-md border border-input bg-muted px-3 py-2 text-foreground opacity-60"
                />
                <p class="mt-1 text-xs text-muted-foreground">Organization name cannot be changed.</p>
              </div>
              <div>
                <label for="org-id" class="block text-sm font-medium text-foreground mb-1">Organization ID</label>
                <input
                  type="text"
                  id="org-id"
                  value={organization.id}
                  disabled
                  class="w-full rounded-md border border-input bg-muted px-3 py-2 text-foreground opacity-60 font-mono text-sm"
                />
                <p class="mt-1 text-xs text-muted-foreground">Unique identifier for your organization.</p>
              </div>
            </form>

            <div class="mt-8 pt-6 border-t border-border">
              <h3 class="text-lg font-semibold text-foreground mb-4">Danger zone</h3>
              <div class="rounded-lg border border-red-200 bg-red-50 dark:border-red-900/30 dark:bg-red-900/10 p-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium text-red-900 dark:text-red-400">Delete organization</p>
                    <p class="text-sm text-red-700 dark:text-red-400/80">This will permanently delete your organization and all associated data.</p>
                  </div>
                  <button
                    type="button"
                    disabled
                    class="rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white opacity-50 cursor-not-allowed"
                  >
                    Delete
                  </button>
                </div>
              </div>
            </div>
          </section>
        )}
      </main>
    </div>
  </div>
</Layout>
