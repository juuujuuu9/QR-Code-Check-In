---
import Layout from '../../layouts/Layout.astro';
import DashboardHeader from '../../components/DashboardHeader.astro';
import {
  getOrganizationByOwnerUserId,
  getOrganizationMembershipsForUser,
} from '../../lib/db';

const userId = Astro.locals.user?.id ?? '';
const organization = userId ? await getOrganizationByOwnerUserId(userId) : null;
const memberships = userId ? await getOrganizationMembershipsForUser(userId) : [];
---

<Layout title="Organization">
  <div class="min-h-screen bg-background">
    <DashboardHeader
      homeHref="/admin"
      homeLabel="Dashboard"
      showThemeToggle={true}
      showSignOut={true}
      isAdmin={Astro.locals.isAdmin}
      userEmail={Astro.locals.user?.email ?? ''}
      userRole={Astro.locals.user?.role ?? ''}
      inviteButtonId="open-invite-staff-modal-header"
      secondaryLinks={[{ href: '/admin/organization', label: 'Organization' }]}
    />
    <main class="mx-auto max-w-6xl px-4 py-10 space-y-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold text-foreground">Organization settings</h1>
          <p class="mt-1 text-sm text-muted-foreground">Manage team access and invitation status.</p>
        </div>
        {organization && Astro.locals.isAdmin && (
          <button
            id="open-invite-staff-modal-page"
            data-open-invite-staff-modal="true"
            type="button"
            class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90"
          >
            Invite Staff
          </button>
        )}
      </div>

      {!organization ? (
        <div class="rounded-lg border border-(--amber-6) bg-(--amber-2) p-4 text-(--amber-11)">
          <p class="font-medium">No organizer organization found</p>
          <p class="mt-1 text-sm">Create one first to invite staff.</p>
          <a href="/onboarding/organization" class="mt-3 inline-flex rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">
            Create organization
          </a>
        </div>
      ) : (
        <>
          <section class="rounded-xl border border-border bg-card p-6">
            <h2 class="text-lg font-semibold text-foreground">{organization.name}</h2>
            <p class="mt-1 text-sm text-muted-foreground">One organization per organizer on the current plan.</p>
          </section>

          <p id="organization-page-status" class="min-h-5 text-sm text-muted-foreground"></p>

          <section class="rounded-xl border border-border bg-card">
            <div class="border-b border-border px-6 py-4">
              <h2 class="text-lg font-semibold text-foreground">Your memberships</h2>
            </div>
            {memberships.length === 0 ? (
              <p class="px-6 py-6 text-sm text-muted-foreground">No memberships found.</p>
            ) : (
              <div class="overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                  <thead class="border-b border-border text-xs uppercase tracking-wide text-muted-foreground">
                    <tr>
                      <th class="px-6 py-3 font-medium">Role</th>
                      <th class="px-6 py-3 font-medium">Organization ID</th>
                    </tr>
                  </thead>
                  <tbody>
                    {memberships.map((membership) => (
                      <tr class="border-b border-border/80 last:border-b-0">
                        <td class="px-6 py-4 font-medium text-foreground">{membership.role}</td>
                        <td class="px-6 py-4 text-muted-foreground">{membership.organizationId}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </section>
        </>
      )}
    </main>
  </div>

  {organization && Astro.locals.isAdmin && (
    <div
      id="invite-staff-modal"
      class="fixed inset-0 z-70 hidden items-center justify-center bg-black/60 px-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="invite-staff-modal-title"
    >
      <div class="w-full max-w-md rounded-xl border border-border bg-card p-5 shadow-2xl">
        <h2 id="invite-staff-modal-title" class="text-2xl font-bold text-foreground">Invite user</h2>
        <p class="mt-1 text-sm text-muted-foreground">Invite a staff member to your organization by email.</p>

        <form id="invite-staff-form" class="mt-5 space-y-4">
          <div>
            <label for="invite-staff-email" class="mb-1 block text-sm font-medium text-foreground">Email</label>
            <input
              id="invite-staff-email"
              type="email"
              required
              placeholder="staff@example.com"
              class="w-full rounded-md border border-input bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            />
          </div>

          <p id="invite-staff-status" class="min-h-5 text-sm text-muted-foreground"></p>

          <div class="mt-2 flex gap-3">
            <button
              id="cancel-invite-staff-modal"
              type="button"
              class="flex-1 rounded-md border border-border bg-muted px-3 py-2 text-sm font-semibold text-foreground hover:bg-muted/80"
            >
              Cancel
            </button>
            <button
              id="submit-invite-staff"
              type="submit"
              class="flex-1 rounded-md bg-primary px-3 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90 disabled:opacity-60"
            >
              Invite
            </button>
          </div>
        </form>
      </div>
    </div>
  )}

  <script>
    const modal = document.getElementById('invite-staff-modal');
    const openButtons = [
      document.getElementById('open-invite-staff-modal-header'),
      ...document.querySelectorAll('[data-open-invite-staff-modal]'),
    ];
    const cancelButton = document.getElementById('cancel-invite-staff-modal');
    const form = document.getElementById('invite-staff-form');
    const emailInput = document.getElementById('invite-staff-email');
    const status = document.getElementById('invite-staff-status');
    const pageStatus = document.getElementById('organization-page-status');
    const submitButton = document.getElementById('submit-invite-staff');

    const openModal = () => {
      if (!(modal instanceof HTMLElement)) return;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      if (emailInput instanceof HTMLInputElement) emailInput.focus();
      if (status instanceof HTMLElement) {
        status.textContent = '';
        status.className = 'min-h-5 text-sm text-muted-foreground';
      }
    };

    const closeModal = () => {
      if (!(modal instanceof HTMLElement)) return;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      if (form instanceof HTMLFormElement) form.reset();
      if (status instanceof HTMLElement) {
        status.textContent = '';
        status.className = 'min-h-5 text-sm text-muted-foreground';
      }
    };

    openButtons.forEach((button) => {
      button?.addEventListener('click', openModal);
    });
    cancelButton?.addEventListener('click', closeModal);

    modal?.addEventListener('click', (event) => {
      if (event.target === modal) closeModal();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal instanceof HTMLElement && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const email = emailInput instanceof HTMLInputElement ? emailInput.value.trim() : '';
      if (!email) return;
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;
      if (status instanceof HTMLElement) {
        status.textContent = 'Sending invite...';
        status.className = 'min-h-5 text-sm text-muted-foreground';
      }
      try {
        const res = await fetch('/api/organizations/invitations', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          if (status instanceof HTMLElement) {
            status.textContent = body.error || `Error ${res.status}`;
            status.className = 'min-h-5 text-sm text-[var(--red-11)]';
          }
          return;
        }
        if (status instanceof HTMLElement) {
          if (body?.communication?.sent) {
            status.textContent = 'Invite email sent.';
            status.className = 'min-h-5 text-sm text-[var(--green-11)]';
          } else {
            const reason = body?.communication?.error || 'Email service is not configured';
            status.textContent = `Invite created, but email was not sent: ${reason}`;
            status.className = 'min-h-5 text-sm text-[var(--amber-11)]';
          }
        }
        if (pageStatus instanceof HTMLElement) {
          pageStatus.textContent = 'Invite sent. Refreshing list...';
          pageStatus.className = 'min-h-5 text-sm text-[var(--green-11)]';
        }
        window.setTimeout(() => {
          window.location.reload();
        }, 500);
      } catch {
        if (status instanceof HTMLElement) {
          status.textContent = 'Could not send invite';
          status.className = 'min-h-5 text-sm text-[var(--red-11)]';
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
      }
    });

  </script>
</Layout>
