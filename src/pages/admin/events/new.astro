---
import Layout from '../../../layouts/Layout.astro';
import DashboardHeader from '../../../components/DashboardHeader.astro';
import { getEventForOrganization, getOrganizationByOwnerUserId } from '../../../lib/db';

const userId = Astro.locals.user?.id ?? '';
const organization = userId ? await getOrganizationByOwnerUserId(userId) : null;
const existingEvent = organization ? await getEventForOrganization(organization.id) : null;
---

<Layout title="New Event">
  <div class="min-h-screen bg-background">
    <DashboardHeader
      homeHref="/admin/events"
      homeLabel="Events"
      secondaryLinks={[{ href: '/admin', label: 'Attendees' }]}
    />

    <main class="max-w-2xl mx-auto px-2 sm:px-6 lg:px-8 py-8">
      <h1 class="text-2xl font-bold text-foreground mb-6">New event</h1>

      {!organization && (
        <div class="mb-6 rounded-lg border border-[var(--amber-6)] bg-[var(--amber-2)] p-4 text-[var(--amber-11)]">
          <p class="font-medium">Create an organization first</p>
          <p class="mt-1 text-sm">You need an organization before you can create events.</p>
          <a href="/onboarding/organization" class="mt-3 inline-flex rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">
            Create organization
          </a>
        </div>
      )}

      {organization && existingEvent && (
        <div class="mb-6 rounded-lg border border-[var(--amber-6)] bg-[var(--amber-2)] p-4 text-[var(--amber-11)]">
          <p class="font-medium">Event limit reached</p>
          <p class="mt-1 text-sm">This organization already has an event. Multi-event access is planned for a future paid tier.</p>
          <a href="/admin/events" class="mt-3 inline-flex rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">
            Back to events
          </a>
        </div>
      )}

      <form id="new-event-form" class={`space-y-4 rounded-lg border border-border bg-card p-6 shadow-sm ${(!organization || existingEvent) ? 'opacity-60 pointer-events-none' : ''}`}>
        <div>
          <label for="name" class="block text-sm font-medium text-muted-foreground mb-1">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full rounded border border-input bg-background px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
            placeholder="e.g. Summer Party 2024"
          />
        </div>
        <div>
          <label for="slug" class="block text-sm font-medium text-muted-foreground mb-1">Slug (URL-friendly)</label>
          <input
            type="text"
            id="slug"
            name="slug"
            class="w-full rounded border border-input bg-background px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
            placeholder="e.g. summer-party-2024"
          />
          <p class="mt-1 text-xs text-muted-foreground">Used in webhooks and URLs. Lowercase, no spaces.</p>
          <p id="slug-illegal-chars" class="mt-1 text-xs text-[var(--amber-11)] hidden">Some characters cannot be used in slugs and were removed:</p>
        </div>
        <div>
          <label for="micrositeUrl" class="block text-sm font-medium text-muted-foreground mb-1">Microsite URL (optional)</label>
          <input
            type="url"
            id="micrositeUrl"
            name="micrositeUrl"
            class="w-full rounded border border-input bg-background px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
            placeholder="https://..."
          />
        </div>
        <div id="form-error" class="hidden text-sm text-[var(--red-11)]"></div>
        <div class="flex gap-3">
          <button
            type="submit"
            class="rounded bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-[var(--color-primary-hover)] disabled:opacity-50"
          >
            Create event
          </button>
          <a href="/admin/events" class="rounded border border-border px-4 py-2 text-sm font-medium text-muted-foreground hover:bg-muted">
            Cancel
          </a>
        </div>
      </form>
    </main>
  </div>

  <script>
    const form = document.getElementById('new-event-form') as HTMLFormElement;
    const nameInput = document.getElementById('name') as HTMLInputElement;
    const slugInput = document.getElementById('slug') as HTMLInputElement;
    const errorEl = document.getElementById('form-error');
    const illegalCharsEl = document.getElementById('slug-illegal-chars');

    function nameToSlug(name: string): { slug: string; illegalChars: string[] } {
      const slug = name
        .trim()
        .toLowerCase()
        .replace(/\s+/g, '-')
        .replace(/[^a-z0-9-]/g, '')
        .replace(/-+/g, '-')  // collapse multiple hyphens
        .replace(/^-|-$/g, '');  // trim leading/trailing hyphens
      const allowed = /[a-z0-9\s-]/;
      const illegalChars = [...new Set(
        name.split('').filter((c) => !allowed.test(c.toLowerCase()))
      )];
      return { slug, illegalChars };
    }

    function syncSlugFromName() {
      if (!nameInput || !slugInput || !illegalCharsEl) return;
      const name = nameInput.value;
      const { slug, illegalChars } = nameToSlug(name);
      slugInput.value = slug;
      if (illegalChars.length > 0) {
        illegalCharsEl.textContent = `Some characters cannot be used in slugs and were removed: ${illegalChars.join(' ')}`;
        illegalCharsEl.classList.remove('hidden');
      } else {
        illegalCharsEl.classList.add('hidden');
      }
    }

    nameInput?.addEventListener('input', syncSlugFromName);

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!errorEl) return;
      errorEl.classList.add('hidden');
      const name = (nameInput?.value ?? '').trim();
      let slug = (slugInput?.value ?? '').trim().toLowerCase()
        .replace(/\s+/g, '-')
        .replace(/[^a-z0-9-]/g, '')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
      if (!slug && name) slug = nameToSlug(name).slug;
      if (!name) {
        errorEl.textContent = 'Name is required';
        errorEl.classList.remove('hidden');
        return;
      }
      if (!slug) {
        errorEl.textContent = 'Slug is required. Use only letters, numbers, and hyphens.';
        errorEl.classList.remove('hidden');
        return;
      }
      const micrositeUrl = (document.getElementById('micrositeUrl') as HTMLInputElement)?.value?.trim() || undefined;
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      try {
        const res = await fetch('/api/events', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, slug, micrositeUrl }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          errorEl.textContent = data.error || `Error ${res.status}`;
          errorEl.classList.remove('hidden');
          return;
        }
        window.location.href = '/admin?event=' + (data.id ?? '');
      } catch (err) {
        errorEl.textContent = 'Failed to create event. Try again.';
        errorEl.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
      }
    });
  </script>
</Layout>
