---
import Layout from '../layouts/Layout.astro';
import { SignIn } from '@clerk/astro/components';

const required = Astro.url.searchParams.get('required');
const error = Astro.url.searchParams.get('error');
const returnToRaw = Astro.url.searchParams.get('returnTo');
const safeReturnTo =
  returnToRaw && returnToRaw.startsWith('/') && !returnToRaw.startsWith('//')
    ? returnToRaw
    : '/';

const signUpUrl = `/signup${returnToRaw ? `?returnTo=${encodeURIComponent(safeReturnTo)}` : ''}`;

function canAccessPath(path: string, role: 'organizer' | 'staff' | 'none' | null): boolean {
  if (!role) return false;
  if (role === 'organizer' || role === 'staff') return true;
  if (role === 'none') {
    return path.startsWith('/onboarding') || path.startsWith('/invite');
  }
  return false;
}

const { userId } = Astro.locals.auth();
const currentRole = (Astro.locals.user?.role ?? null) as 'organizer' | 'staff' | 'none' | null;
let blockedSignedIn = false;
if (userId) {
  if (canAccessPath(safeReturnTo, currentRole)) {
    return Astro.redirect(safeReturnTo);
  }
  const roleHome = currentRole === 'none' ? '/onboarding/organization' : '/admin';
  if (roleHome && canAccessPath(roleHome, currentRole)) {
    return Astro.redirect(roleHome);
  }
  blockedSignedIn = true;
}
---

<Layout title="Login | Staff Access">
  <div class="min-h-screen flex items-center justify-center bg-background px-8">
    <div class="max-w-md w-full bg-card p-8 rounded-lg shadow-md border border-border">
      <h1 class="text-2xl font-bold mb-2 text-center text-foreground">Staff Access</h1>
      <p class="text-muted-foreground text-center mb-6">
        {required === 'staff'
          ? 'Sign in to access this area.'
          : 'Sign in to continue.'}
      </p>

      {error && (
        <div class="bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4">
          Sign-in failed. Please try again.
        </div>
      )}

      {blockedSignedIn ? (
        <div class="space-y-4">
          <div class="bg-amber-50 dark:bg-amber-950 border border-amber-200 dark:border-amber-800 text-amber-900 dark:text-amber-200 px-4 py-3 rounded">
            Your account is signed in, but setup is incomplete.
            Create your organization or accept a staff invitation to continue.
          </div>
          <a
            href="/onboarding/organization"
            class="inline-flex w-full items-center justify-center rounded-md bg-primary px-4 py-2 text-primary-foreground font-medium hover:bg-primary/90 transition-colors"
          >
            Continue setup
          </a>
          <a
            href="/api/auth/signout?callbackUrl=/login"
            class="inline-flex w-full items-center justify-center rounded-md bg-primary px-4 py-2 text-primary-foreground font-medium hover:bg-primary/90 transition-colors"
          >
            Sign out and switch account
          </a>
        </div>
      ) : (
        <>
          <SignIn
            routing="hash"
            fallbackRedirectUrl={safeReturnTo}
            signUpUrl={signUpUrl}
            appearance={{
              elements: {
                formButtonPrimary:
                  'bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md font-medium transition-colors',
                formFieldInput:
                  'flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50',
                card: 'shadow-none border-0 bg-transparent',
                headerTitle: 'hidden',
                headerSubtitle: 'hidden',
                socialButtonsBlockButton:
                  'flex items-center justify-center gap-2 px-4 py-3 border border-border rounded-lg hover:bg-muted transition-colors cursor-pointer font-medium text-foreground',
                dividerLine: 'bg-border',
                dividerText: 'text-muted-foreground text-sm',
                formFieldLabel: 'text-sm font-medium text-foreground',
                footer: 'hidden',
              },
            }}
          />

          <p class="text-center text-sm text-muted-foreground mt-6">
            Don't have an account?{' '}
            <a href={signUpUrl} class="text-primary hover:text-primary/80 font-medium">Sign up</a>
          </p>
        </>
      )}
    </div>
  </div>
</Layout>
