# Database (Neon or any PostgreSQL)
DATABASE_URL=postgresql://username:password@ep-xxxxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# Email (Resend: https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# For testing without a verified domain: use onboarding@resend.dev and only send to the email you signed up to Resend with.
# For production: verify your domain at resend.com/domains, then use e.g. events@yourdomain.com
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Event Check-In

# CORS (origin of the frontend, e.g. dev server or production URL)
CORS_ORIGIN=http://localhost:5173

# Auth (Clerk: https://dashboard.clerk.com)
# Get these from your Clerk dashboard → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Clerk sign-in/sign-up redirect URLs (defaults work for most cases)
# CLERK_SIGN_IN_URL=/login
# CLERK_SIGN_UP_URL=/login
# CLERK_SIGN_IN_FALLBACK_URL=/admin
# CLERK_SIGN_UP_FALLBACK_URL=/admin
# Access control is app-managed (organizations, memberships, invitations).
# Run:
#   npm run migrate-events
#   npm run migrate-organizations
# Existing Clerk users can continue as-is; organization ownership/membership is stored in DB.

# Central hub (multi-event, webhook). Generate key: openssl rand -hex 32
MICROSITE_WEBHOOK_KEY=
# Default event slug for in-app RSVP and legacy QR. Run npm run migrate-events first.
DEFAULT_EVENT_SLUG=default

# Optional
PORT=4321
# Optional: absolute app URL used in invitation emails (falls back to request origin / VERCEL_URL)
# APP_URL=https://yourdomain.com
# QR token validity in days (default 7). Imported/printed QRs must be valid until the event.
# QR_TOKEN_TTL_DAYS=7

# Demo codes (training mode)
# Demo QR codes (DEMO-SUCCESS, DEMO-ALREADY, DEMO-INVALID) work automatically in development.
# Set to 'true' to enable on production for staff scanner training.
# These codes return canned responses and never modify the database.
# ENABLE_DEMO_CODES=false